# Copy to .env and fill in real values from the Supabase dashboard.
# Never commit .env — only this .example file is tracked.

# Pooler connection string — port 6543, "Transaction" mode
# (Project Settings -> Database -> Connection pooling). NOT the direct 5432 URL.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Legacy shared JWT secret (Project Settings -> API -> JWT Secret).
# Only used as a fallback — most projects verify via JWKS (see SUPABASE_URL below).
SUPABASE_JWT_SECRET=your-jwt-secret

# Project URL, used to fetch /auth/v1/.well-known/jwks.json for JWT verification.
SUPABASE_URL=https://xxxx.supabase.co

# Allowed browser origin for CORS. Local dev: http://localhost:3000
# Production: your Vercel domain, e.g. https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:3000

# "development" enables localhost CORS; anything else is treated as production
ENVIRONMENT=development

# Port the Go server listens on (Fly.io expects 8080)
PORT=8080

# Project Settings -> API -> service_role key. SECRET — server-side only,
# used to create signed Storage upload/read URLs for meal photos. Never send
# this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket for meal photos. Create it in Supabase Dashboard ->
# Storage -> New bucket, name "meal-photos", set to Private.
MEAL_PHOTOS_BUCKET=meal-photos

# console.anthropic.com -> API Keys. Used for photo -> calorie/macro estimation.
ANTHROPIC_API_KEY=sk-ant-...

# A vision-capable Claude model id, e.g. claude-sonnet-4-5-20250929
ANTHROPIC_MODEL=

# Public Supabase Storage bucket for profile pictures (Dashboard -> Storage ->
# New bucket -> Public, name "avatars"). Defaults to "avatars" if unset.
AVATARS_BUCKET=avatars

# Shared secret Cloud Scheduler sends as the X-Internal-Secret header to hit
# /api/internal/cron/* (morning/evening reminders, milestone checks). Generate
# with `openssl rand -hex 32`; must match the scheduler job config.
CRON_SECRET=

# Web Push VAPID keypair, used to sign push notifications. Generate a pair
# with webpush.GenerateVAPIDKeys() from github.com/SherClockHolmes/webpush-go
# (e.g. via a throwaway `go run` script). Public key is also served to the
# frontend via GET /api/push/vapid-public-key — never baked into the build.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact address identifying this app to push services: a plain email
# address, or an https:// URL. Do NOT include a "mailto:" prefix — the
# webpush-go library adds it automatically, and a pre-included prefix
# becomes "mailto:mailto:..." in the VAPID JWT, which Apple's push service
# rejects outright (403 BadJwtToken) while Chrome/FCM silently tolerates it.
# e.g. you@perigee.fit
VAPID_SUBJECT=

# Free API key from fdc.nal.usda.gov/api-key-signup.html — used as a second
# barcode lookup (Branded Foods dataset) when Open Food Facts has no match.
# Optional: barcode scanning still works with just Open Food Facts if unset.
USDA_FDC_API_KEY=

# FatSecret Platform API (platform.fatsecret.com) — free tier is 5,000
# requests/day, personal/non-commercial use, and requires showing a
# "Powered by FatSecret" attribution wherever results are displayed.
# Used for food search when logging meals.
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
