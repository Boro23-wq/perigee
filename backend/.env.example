# Copy to .env and fill in real values from the Supabase dashboard.
# Never commit .env — only this .example file is tracked.

# Pooler connection string — port 6543, "Transaction" mode
# (Project Settings -> Database -> Connection pooling). NOT the direct 5432 URL.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Legacy shared JWT secret (Project Settings -> API -> JWT Secret).
# Only used as a fallback — most projects verify via JWKS (see SUPABASE_URL below).
SUPABASE_JWT_SECRET=your-jwt-secret

# Project URL, used to fetch /auth/v1/.well-known/jwks.json for JWT verification.
SUPABASE_URL=https://xxxx.supabase.co

# Allowed browser origin for CORS. Local dev: http://localhost:3000
# Production: your Vercel domain, e.g. https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:3000

# "development" enables localhost CORS; anything else is treated as production
ENVIRONMENT=development

# Port the Go server listens on (Fly.io expects 8080)
PORT=8080

# Project Settings -> API -> service_role key. SECRET — server-side only,
# used to create signed Storage upload/read URLs for meal photos. Never send
# this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket for meal photos. Create it in Supabase Dashboard ->
# Storage -> New bucket, name "meal-photos", set to Private.
MEAL_PHOTOS_BUCKET=meal-photos

# console.anthropic.com -> API Keys. Used for photo -> calorie/macro estimation.
ANTHROPIC_API_KEY=sk-ant-...

# A vision-capable Claude model id, e.g. claude-sonnet-4-5-20250929
ANTHROPIC_MODEL=
