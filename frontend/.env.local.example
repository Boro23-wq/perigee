# Copy to .env.local and fill in real values from the Supabase dashboard.
# Never commit .env.local — only this .example file is tracked.

# Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Project Settings -> API -> anon public key. Public — safe in the browser, RLS is the wall.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Base URL of the Go backend. Local dev: http://localhost:8080
# Production: your Fly.io URL, e.g. https://your-app.fly.dev
NEXT_PUBLIC_API_URL=http://localhost:8080
